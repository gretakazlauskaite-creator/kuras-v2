/public/uploads/*
!/public/uploads/.gitkeep

# ── Temp / cache ──────────────────────────────────────────────
/tmp/
/var/
*.cache

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────
*.log
/logs/

# ── PHP ───────────────────────────────────────────────────────
*.phar
