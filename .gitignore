# ── Dependencies ─────────────────────────────────────────────
/vendor/
/composer.lock

# ── Environment & secrets ─────────────────────────────────────
.env
*.env.local
*.env.*.local

# ── DDEV ──────────────────────────────────────────────────────
.ddev/.gitignore
.ddev/config.*.yaml
.ddev/docker-compose.*.yaml
.ddev/.homeadditions/

