# Database
DB_DSN=mysql:host=db;dbname=db;charset=utf8mb4
DB_USER=db
DB_PASS=db
DB_NAME=db

# App
APP_URL=https://kuras-pricer.ddev.site
APP_ENV=development

# Replace with the contracted map-tile provider in staging/production.
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION="© OpenStreetMap contributors"

# Contracted or self-hosted Photon-compatible geocoder. Leave empty to disable.
GEOCODING_PROVIDER=photon
GEOCODING_ENDPOINT=

# LEA import safety
IMPORT_STORAGE_PATH=/var/www/html/var/imports
IMPORT_MIN_STATIONS=100
IMPORT_MIN_PRICES=100
IMPORT_MAX_SOURCE_AGE_DAYS=7

# Admin
ADMIN_USER=admin
ADMIN_PASS=change_me_strong_password
ADMIN_EMAIL=admin@example.com

# Mail (symfony/mailer DSN)
MAIL_DSN=smtp://localhost:1025
MAIL_FROM=noreply@kuras.pricer.lt
MAIL_FROM_NAME="Kuras Pricer"
